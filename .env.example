# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/fintrack"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""          # openssl rand -base64 32

# ─── OAuth (optional — remove if not using) ──────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Plaid ───────────────────────────────────────────────────────────────────
# Get these from dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=""
PLAID_SECRET=""             # Use the sandbox secret while testing
PLAID_ENV="sandbox"         # sandbox | development | production

# ─── Encryption (for storing Plaid access tokens at rest) ────────────────────
ENCRYPTION_KEY=""           # openssl rand -hex 32

# ─── Anthropic Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Uses Gmail SMTP by default — works with App Passwords.
# For other providers, change SMTP_HOST / SMTP_PORT accordingly.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@fintrack.app"

# ─── Push Notifications (VAPID) ───────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@fintrack.app"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
