{
  "name": "fintrack",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "apk": "npx cap sync android && cd android && ./gradlew assembleDebug",
    "apk:release": "npx cap sync android && cd android && ./gradlew assembleRelease",
    "ipa": "npx cap sync ios && cd ios && xcodebuild -workspace App.xcworkspace -scheme App -configuration Release archive -archivePath build/App.xcarchive && xcodebuild -exportArchive -archivePath build/App.xcarchive -exportPath build/App -exportOptionsPlist ExportOptions.plist",
    "vapid:generate": "npx web-push generate-vapid-keys"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/push-notifications": "^6.0.5",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.17.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "next": "15.5.19",
    "next-auth": "4.24.14",
    "nodemailer": "^7.0.13",
    "plaid": "^42.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plaid-link": "^4.1.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.11",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.5.10",
