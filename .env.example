# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/fintrack"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""          # openssl rand -base64 32

# ─── OAuth (optional — remove if not using) ──────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Plaid ───────────────────────────────────────────────────────────────────
# Get these from dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=""
PLAID_SECRET=""             # Use the sandbox secret while testing
PLAID_ENV="sandbox"         # sandbox | development | production

# ─── Encryption (for storing Plaid access tokens at rest) ────────────────────
ENCRYPTION_KEY=""           # openssl rand -hex 32

# ─── Anthropic Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
